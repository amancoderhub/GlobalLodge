<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>GlobalLodge</title>
</head>
<body>
    <h3>Create a New Listing</h3>
    <form method="post" action="/listings">
        <input name="title" placeholder="enter title" type="text">
        <br>
        <textarea name="title" placeholder="enter description" type="text"></textarea>
        <br>
        <input name="image" placeholder="enter image URL/Link">
        <br>
        <input name="price" placeholder="enter price" type="number">
        <br>
        <input name="location" placeholder="enter location" type="text">
        <br>
        <input name="country" placeholder="enter country" type="text">
        <br>
        <button>Add</button>
    </form>
</body>
</html>