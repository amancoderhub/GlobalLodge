<% layout("/layouts/boilerplate") %>

  <!-- Page Content -->
  <div class="container-fluid px-md-5">

    <!-- Hero Section -->
    <div class="hero-section" data-aos="zoom-out" data-aos-duration="1200">
      <div class="hero-content px-4">
        <h1 class="display-3">Find Your Next Adventure</h1>
        <p class="lead">Explore unique homes, cabins, and more around the world.</p>

        <form action="/listings" method="GET" class="d-flex justify-content-center mt-4">
          <div class="search-wrapper position-relative" style="width: 100%; max-width: 600px;">
            <input type="text" name="q" class="form-control form-control-lg border-0 shadow-lg ps-5 rounded-pill"
              placeholder="Search destinations (e.g. Goa, Shimla)" value="<%= typeof q !== 'undefined' ? q : '' %>"
              style="height: 60px; font-size: 1.1rem;">
            <i class="fa-solid fa-magnifying-glass position-absolute text-muted"
              style="left: 20px; top: 18px; font-size: 1.4rem;"></i>
            <button class="btn bg-fe424d text-white position-absolute rounded-pill px-4"
              style="right: 8px; top: 8px; height: 44px; font-weight: 700;">Search</button>
          </div>
        </form>
      </div>
    </div>

    <!-- Filters Wrapper -->
    <div id="filters-wrapper" class="d-flex align-items-center justify-content-between flex-wrap py-4 mt-2">

      <div id="filters" class="d-flex align-items-center flex-grow-1 overflow-auto">
        <% const categories=[ { name: "Trending" , icon: "fa-fire" }, { name: "Rooms" , icon: "fa-bed" }, {
          name: "Iconic Cities" , icon: "fa-mountain-city" }, { name: "Mountains" , icon: "fa-mountain" }, {
          name: "Castles" , icon: "fa-fort-awesome" }, { name: "Amazing Pools" , icon: "fa-person-swimming" }, {
          name: "Camping" , icon: "fa-campground" }, { name: "Farms" , icon: "fa-cow" }, { name: "Arctic" ,
          icon: "fa-snowflake" }, { name: "Islands" , icon: "fa-ship" } ]; %>

          <% for(let cat of categories) { %>
            <div class="filter me-4" onclick="window.location.href='/listings?category=<%= cat.name %>'">
              <div><i class="fa-solid <%= cat.icon %>"></i></div>
              <p>
                <%= cat.name %>
              </p>
            </div>
            <% } %>
      </div>

      <div class="tax-toggle ms-md-4 mt-3 mt-md-0 shadow-sm bg-white p-3 rounded-4 d-flex align-items-center">
        <div class="form-check-reverse form-switch">
          <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault"
            style="cursor: pointer;">
          <label class="form-check-label fw-bold text-secondary" for="switchCheckDefault"
            style="cursor: pointer; margin-right: 10px;">Display total after taxes</label>
        </div>
      </div>
    </div>

    <!-- Listings Grid -->
    <% if(allListings.length===0) { %>
      <div class="text-center py-5 my-5" data-aos="fade-up">
        <i class="fa-solid fa-map-location-dot display-1 text-muted opacity-25 mb-4"></i>
        <h2 class="fw-bold">No listings found</h2>
        <p class="text-muted fs-5">Try adjusting your filters or search keywords.</p>
        <a href="/listings" class="btn btn-dark rounded-pill px-5 py-3 mt-3">View All Listings</a>
      </div>
      <% } else { %>
        <div class="row row-cols-lg-4 row-cols-md-3 row-cols-sm-2 row-cols-1 g-4 mt-2">
          <% for (let listing of allListings) { %>
            <div class="col" data-aos="fade-up">
              <a href="/listings/<%= listing._id %>" class="listing-link">
                <div class="card h-100 listing-card border-0">
                  <div class="card-img-container position-relative overflow-hidden">
                    <% let imageUrl; if (listing.image && listing.image.url) {
                      imageUrl=listing.image.url.startsWith("http") ? listing.image.url :
                      `https://res.cloudinary.com/devf9qie2/image/upload/${listing.image.url}`; } else {
                      imageUrl="/images/default.jpg" ; } %>
                      <img src="<%= imageUrl %>" class="card-img-top" alt="listing_image" style="height: 18rem;">
                      <div class="card-img-overlay d-flex align-items-end p-3">
                        <span class="badge bg-white text-dark rounded-pill px-3 py-2 shadow-sm">View Details</span>
                      </div>
                  </div>
                  <div class="card-body">
                    <h5 class="card-title fw-bold mb-1 text-truncate">
                      <%= listing.title %>
                    </h5>
                    <p class="text-muted small mb-2"><i class="fa-solid fa-location-dot me-1"></i>
                      <%= listing.location %>, <%= listing.country %>
                    </p>
                    <div class="d-flex align-items-center justify-content-between mt-auto">
                      <p class="card-text mb-0">
                        <span class="fs-5 fw-bold text-dark">₹<%= listing.price.toLocaleString("en-IN") %></span>
                        <span class="text-muted small">/ night</span>
                      </p>
                      <i class="tax-info text-primary-lodge small fw-bold" style="display: none;">+18% GST</i>
                    </div>
                  </div>
                </div>
              </a>
            </div>
            <% } %>
        </div>
        <% } %>
  </div>

  <script>
    // Tax toggle logic
    document.getElementById("switchCheckDefault").addEventListener("change", function () {
      const taxInfo = document.querySelectorAll(".tax-info");
      for (let info of taxInfo) {
        info.style.display = this.checked ? "inline" : "none";
      }
    });

    // Handle Category Scroll with mouse wheel
    const filterBox = document.getElementById("filters");
    filterBox.addEventListener("wheel", (e) => {
      if (e.deltaY !== 0) {
        e.preventDefault();
        filterBox.scrollLeft += e.deltaY;
      }
    });
  </script>